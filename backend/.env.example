# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/HelpDesk

# LDAP
LDAP_SERVER=DC03.atg.uz
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_BASE_DN=DC=atg,DC=uz
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=helpdesk-files
MINIO_SECURE=false

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# App
CORS_ORIGINS=http://localhost:3000
# First user to log in becomes Global Admin (true for local, false in production)
AUTO_ADMIN_FIRST_USER=true

LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=admin123
LOCAL_USERS=user1:1234,user2:1234,user3:1234,user4:1234,user5:1234,user6:1234,user7:1234,user8:1234,user9:1234,user10:1234
